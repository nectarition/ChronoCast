{
  "hosting": {
    "public": "./dist",
    "predeploy": [
      "yarn build"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "./rules/firestore.rules"
  },
  "storage": {
    "rules": "./rules/storage.rules"
  }
}
