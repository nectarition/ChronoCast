generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  oidcSub   String   @unique
  isActive  Boolean  @default(false)

  @@map("users")
}

model Folder {
  id   Int    @id @default(autoincrement())
  slug String @unique

  sources   Source[]
  schedules Schedule[]

  @@map("folders")
}

model Source {
  id       Int    @id @default(autoincrement())
  folderId Int
  name     String

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  schedules Schedule[]

  @@map("sources")
}

model Schedule {
  id          Int      @id @default(autoincrement())
  folderId    Int
  sourceId    Int
  scheduledAt DateTime

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Restrict)
  source Source @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@map("schedules")
}
